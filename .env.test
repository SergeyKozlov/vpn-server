# Test environment for `make test` and any live smoke tests. Isolated
# from production: separate database (vpn_test), a dead-end XUI endpoint,
# and a no-op Hysteria2 reload command. See ai_from_local/TZ_P2.3_SelfRegistration_Trial.md
# §7 — never point this file at the real 3x-ui panel or a real reload
# command. Safe to commit: no real secrets below.
POSTGRES_USER=vpn_test
POSTGRES_PASSWORD=vpn_test_dummy_pw
POSTGRES_DB=vpn_test
DATABASE_URL=postgres://vpn_test:vpn_test_dummy_pw@localhost:5432/vpn_test?sslmode=disable

XUI_BASE_URL=http://127.0.0.1:59999
XUI_API_TOKEN=test-dummy-token
XUI_INBOUND_ID=1

HYSTERIA_RELOAD_COMMAND=true
HYSTERIA_CONFIG_PATH=/tmp/hysteria_test_config.yaml

APP_ENC_KEY=RLcypWGJYna2GIJauQMJvZH9dOGpT7J/1qeteNTM26U=
