POSTGRES_USER=vpn
POSTGRES_PASSWORD=changeme
POSTGRES_DB=vpn
DATABASE_URL=postgres://vpn:changeme@localhost:5432/vpn?sslmode=disable

# 32 random bytes, base64-encoded, e.g. `openssl rand -base64 32`. Encrypts
# clients.vless_uuid_enc / hysteria2_password_enc at rest.
APP_ENC_KEY=changeme

# Must include the panel's webBasePath, e.g. https://host:2053/xyzsecret
XUI_BASE_URL=changeme
# Settings -> Security -> API Token in the 3x-ui panel
XUI_API_TOKEN=changeme
# The prod VLESS-Reality inbound; defaults to 1 if unset
XUI_INBOUND_ID=1

HYSTERIA_CONFIG_PATH=/path/to/hysteria/config.yaml
# Run after every config.yaml rewrite so Hysteria2 picks up the new
# userpass map, e.g. "systemctl restart hysteria2" or "docker restart hysteria2"
HYSTERIA_RELOAD_COMMAND=changeme
